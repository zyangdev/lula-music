{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lula",
  "version": "0.1.3",
  "identifier": "com.lula.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lula",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/downloads/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/yt-dlp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFNjhCOTk1NEQwNUVGNzQKUldSMDd3Vk5sYmxvYnMrT3Vld3NSMjdodEZzTUZaUHUxVE9IZUFtSXNpSlRLRDd3NDVZaWdSaU8K",
      "endpoints": [
        "https://github.com/zyangdev/lula-music/releases/latest/download/latest.json"
      ]
    }
  }
}
